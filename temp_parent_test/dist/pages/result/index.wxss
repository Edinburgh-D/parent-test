.result{background:-webkit-gradient(linear,left top,left bottom,from(#f8f9ff),to(#fff));background:-webkit-linear-gradient(top,#f8f9ff,#fff);background:linear-gradient(180deg,#f8f9ff,#fff);min-height:100vh;padding:24rpx 20rpx 32rpx}.result-top{margin-bottom:20rpx;text-align:center}.result-badge{background:-webkit-linear-gradient(315deg,#4f46e5,#7c3aed);background:linear-gradient(135deg,#4f46e5,#7c3aed);border-radius:20rpx;color:#fff;display:inline-block;font-size:12rpx;font-weight:600;margin-bottom:16rpx;padding:6rpx 16rpx}.result-type{color:#1e1b4b;display:block;font-size:32rpx;font-weight:800;margin-bottom:8rpx}.result-subtitle{color:#6b7280;display:block;font-size:14rpx}.result-card{background:#fff;border-radius:20rpx;-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);margin-bottom:16rpx;padding:24rpx}.result-section-title{color:#1e1b4b;display:block;font-size:15rpx;font-weight:700;margin-bottom:16rpx}.result-desc{color:#4b5563;display:block;font-size:14rpx;line-height:1.8}.result-tip{background:-webkit-linear-gradient(315deg,#fef3c7,#fde68a);background:linear-gradient(135deg,#fef3c7,#fde68a);border-radius:16rpx;margin-bottom:16rpx;padding:20rpx}.result-tip-title{color:#92400e;display:block;font-size:14rpx;font-weight:700;margin-bottom:8rpx}.result-tip-text{color:#78350f;display:block;font-size:14rpx;line-height:1.7}.result-course{background:-webkit-linear-gradient(315deg,#ecfdf5,#d1fae5);background:linear-gradient(135deg,#ecfdf5,#d1fae5);border-radius:16rpx;margin-bottom:20rpx;padding:20rpx}.result-course-title{color:#065f46;display:block;font-size:14rpx;font-weight:700;margin-bottom:6rpx}.result-course-text{color:#047857;display:block;font-size:14rpx}.score-bars{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:14rpx}.score-bar-item{-ms-flex-align:center;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;