.courses{background:-webkit-gradient(linear,left top,left bottom,from(#f8f9ff),to(#fff));background:-webkit-linear-gradient(top,#f8f9ff,#fff);background:linear-gradient(180deg,#f8f9ff,#fff);min-height:100vh;padding:16rpx 20rpx 32rpx}.courses-header{-ms-flex-align:center;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:12rpx;margin-bottom:8rpx}.courses-back{background:#f3f4f6;border:none;border-radius:50%;color:#374151;font-size:16rpx;height:36rpx;line-height:36rpx;padding:0;text-align:center;width:36rpx}.courses-back::after{border:none}.courses-title{color:#1e1b4b;font-size:20rpx;font-weight:700}.courses-subtitle{color:#6b7280;display:block;font-size:14rpx;margin-bottom:20rpx}.course-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:12rpx}.course-item{background:#fff;border:1rpx solid #f3f4f6;border-radius:16rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);padding:20rpx}.course-item-header{-ms-flex-pack:justify;-ms-flex-align:start;-webkit-align-items:flex-start;align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;justify-content:space-between;margin-bottom:8rpx}.course-item-title{color:#1e1b4b;-webkit-flex:1;-ms-flex:1;flex:1;font-size:15rpx;font-weight:700;line-height:1.4;padding-right:8rpx}.course-tag{-ms-flex-negative:0;background:-webkit-linear-gradient(315deg,#fef3c7,#fde68a);background:linear-gradient(135deg,#fef3c7,#fde68a);border-radius:10rpx;color:#92400e;-webkit-flex-shrink:0;flex-shrink:0;font-size:11rpx;font-weight:600;padding:4rpx 10rpx}.course-item-desc{color:#6b7280;display:block;font-size:13rpx;line-height:1.6;margin-bottom:14rpx}.course-item-footer{-ms-flex-pack:justify;-ms-flex-align:center;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justif