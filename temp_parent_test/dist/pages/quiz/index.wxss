.quiz{background:-webkit-gradient(linear,left top,left bottom,from(#f8f9ff),to(#fff));background:-webkit-linear-gradient(top,#f8f9ff,#fff);background:linear-gradient(180deg,#f8f9ff,#fff);min-height:100vh;padding:16rpx 20rpx 32rpx}.quiz-header{-ms-flex-align:center;-ms-flex-pack:justify;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;justify-content:space-between;margin-bottom:20rpx}.quiz-header-title{color:#1e1b4b;font-size:17rpx;font-weight:600}.quiz-header-close{background:#f3f4f6;border:none;border-radius:50%;color:#6b7280;font-size:18rpx;height:32rpx;line-height:32rpx;padding:0;text-align:center;width:32rpx}.quiz-header-close::after{border:none}.progress-bar{background:#e5e7eb;border-radius:3rpx;height:6rpx;margin-bottom:24rpx;overflow:hidden}.progress-fill{background:-webkit-gradient(linear,left top,right top,from(#4f46e5),to(#7c3aed));background:-webkit-linear-gradient(left,#4f46e5,#7c3aed);background:linear-gradient(90deg,#4f46e5,#7c3aed);border-radius:3rpx;height:100%;-webkit-transition:width .4s ease;transition:width .4s ease}.question-card{background:#fff;border-radius:20rpx;-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);padding:28rpx 24rpx}.question-num{color:#4f46e5;display:block;font-size:13rpx;font-weight:600;margin-bottom:16rpx}.question-text{color:#1e1b4b;display:block;font-size:18rpx;font-weight:600;line-height:1.6;margin-bottom:24rpx}.options{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:10rpx}.option-btn{-ms-flex-align:start;-webkit-align-items:flex-start;align-items:flex-start;background:#f9fafb;border:2rpx solid #f3f4f6;border-radius:14rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:12rpx;padding:16rpx 18rpx;text-align:left;-webkit-transition:all .15s ease;transition:all .15s ease}.option-btn::after{border:none}.option-btn:active{background:#eef2ff;border-color:#4f46e5}.option-index{-ms-flex-align:center;-ms-flex-pack:center;-ms-flex-negative:0;-webkit-align-items:center;align-items:center;background:#e5e7eb;border-radius:50%;color:#6b7280;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-shrink:0;flex-shrink:0;font-size:12rpx;font-weight:600;height:26rpx;-webkit-justify-content:center;justify-content:center;line-height:26rpx;text-align:center;width:26rpx}.option-btn:active .option-index{background:#4f46e5;color:#fff}.option-text{color:#374151;-webkit-flex:1;-ms-flex:1;flex:1;font-size:15rpx;line-height:1.5}